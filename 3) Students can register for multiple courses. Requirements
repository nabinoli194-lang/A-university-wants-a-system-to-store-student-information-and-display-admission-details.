import java.util.ArrayList;
import java.util.List;

// Course class
class Course {
    private String courseName;
    private String courseCode;

    // Constructor
    public Course(String courseName, String courseCode) {
        this.courseName = courseName;
        this.courseCode = courseCode;
    }

    // Getters
    public String getCourseName() {
        return courseName;
    }

    public String getCourseCode() {
        return courseCode;
    }

    // Display course details
    public void displayCourse() {
        System.out.println(courseCode + " - " + courseName);
    }
}

// Student class
class Student {
    private String name;
    private int rollNumber;
    private List<Course> courses; // List of courses per student

    // Constructor
    public Student(String name, int rollNumber) {
        this.name = name;
        this.rollNumber = rollNumber;
        this.courses = new ArrayList<>();
    }

    // Method to register a course
    public void registerCourse(Course course) {
        courses.add(course);
        System.out.println(name + " registered for: " + course.getCourseName());
    }

    // Display student profile with courses
    public void displayProfile() {
        System.out.println("----- Student Profile -----");
        System.out.println("Name: " + name);
        System.out.println("Roll Number: " + rollNumber);
        System.out.println("Registered Courses:");
        for (Course c : courses) {
            c.displayCourse();
        }
    }
}

// Main class
public class UniversityCourses {
    public static void main(String[] args) {
        // Create courses
        Course c1 = new Course("Data Structures", "CS101");
        Course c2 = new Course("Operating Systems", "CS102");
        Course c3 = new Course("Database Systems", "CS103");

        // Create student
        Student s1 = new Student("Nabin", 101);

        // Register courses
        s1.registerCourse(c1);
        s1.registerCourse(c2);
        s1.registerCourse(c3);

        // Display student profile with courses
        s1.displayProfile();
    }
}
