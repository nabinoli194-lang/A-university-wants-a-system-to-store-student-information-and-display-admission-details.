// Abstract Scholarship class
abstract class Scholarship {
    protected String studentName;
    protected String program;

    public Scholarship(String studentName, String program) {
        this.studentName = studentName;
        this.program = program;
    }

    // Abstract method to check eligibility
    public abstract boolean checkEligibility();

    // Display details
    public void displayDetails() {
        System.out.println("Student: " + studentName);
        System.out.println("Program: " + program);
        System.out.println("Eligible: " + checkEligibility());
    }
}

// Merit-based Scholarship
class MeritScholarship extends Scholarship {
    private double gradePoint;

    public MeritScholarship(String studentName, String program, double gradePoint) {
        super(studentName, program);
        this.gradePoint = gradePoint;
    }

    @Override
    public boolean checkEligibility() {
        // Example rule: GPA must be >= 3.5
        return gradePoint >= 3.5;
    }
}

// Need-based Scholarship
class NeedBasedScholarship extends Scholarship {
    private double familyIncome;

    public NeedBasedScholarship(String studentName, String program, double familyIncome) {
        super(studentName, program);
        this.familyIncome = familyIncome;
    }

    @Override
    public boolean checkEligibility() {
        // Example rule: Family income must be <= 50,000
        return familyIncome <= 50000;
    }
}

// Main class to test
public class ScholarshipTest {
    public static void main(String[] args) {
        Scholarship merit = new MeritScholarship("Aarav", "Engineering", 3.8);
        Scholarship need = new NeedBasedScholarship("Sita", "Medical", 40000);

        merit.displayDetails();
        System.out.println("-------------------");
        need.displayDetails();
    }
}
