// Abstract base class
abstract class Scholarship {
    protected String studentName;
    protected String programName;

    public Scholarship(String studentName, String programName) {
        this.studentName = studentName;
        this.programName = programName;
    }

    // Abstract method to check eligibility
    public abstract boolean checkEligibility(double gpa, double familyIncome);

    // Display details
    public void displayDetails() {
        System.out.println("Student: " + studentName);
        System.out.println("Program: " + programName);
    }
}

// Merit-based scholarship
class MeritScholarship extends Scholarship {
    private double requiredGPA;

    public MeritScholarship(String studentName, String programName, double requiredGPA) {
        super(studentName, programName);
        this.requiredGPA = requiredGPA;
    }

    @Override
    public boolean checkEligibility(double gpa, double familyIncome) {
        return gpa >= requiredGPA;
    }
}

// Need-based scholarship
class NeedBasedScholarship extends Scholarship {
    private double incomeThreshold;

    public NeedBasedScholarship(String studentName, String programName, double incomeThreshold) {
        super(studentName, programName);
        this.incomeThreshold = incomeThreshold;
    }

    @Override
    public boolean checkEligibility(double gpa, double familyIncome) {
        return familyIncome <= incomeThreshold;
    }
}

// Test class
public class ScholarshipTest {
    public static void main(String[] args) {
        Scholarship merit = new MeritScholarship("Aarav", "Engineering", 3.5);
        Scholarship need = new NeedBasedScholarship("Priya", "Management", 40000);

        merit.displayDetails();
        System.out.println("Merit Scholarship Eligible: " + merit.checkEligibility(3.7, 60000));

        System.out.println();

        need.displayDetails();
        System.out.println("Need-Based Scholarship Eligible: " + need.checkEligibility(3.0, 35000));
    }
}
